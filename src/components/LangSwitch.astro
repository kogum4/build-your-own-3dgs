---
import type { Lang } from '../i18n/ui';
import { translatePath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const other: Lang = lang === 'ja' ? 'en' : 'ja';
const href = translatePath(Astro.url, other);
const label = other === 'ja' ? '日本語' : 'English';
---

<a class="lang-switch" href={href} aria-label={`Switch language to ${label}`}>
  <svg width="15" height="15" viewBox="0 0 16 16" fill="none" aria-hidden="true">
    <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.3" />
    <path
      d="M1.5 8h13M8 1.5c-1.8 1.8-2.7 4-2.7 6.5s.9 4.7 2.7 6.5c1.8-1.8 2.7-4 2.7-6.5S9.8 3.3 8 1.5Z"
      stroke="currentColor"
      stroke-width="1.3"
    />
  </svg>
  {label}
</a>

<style>
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    line-height: 1;
    background: var(--bg);
  }

  .lang-switch:hover {
    border-color: var(--border-ink);
    color: var(--fg);
    text-decoration: none;
  }
</style>
