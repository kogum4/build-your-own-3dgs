---
import { Image } from 'astro:assets';
import { chapterList } from '../data/chapters';
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/utils';
import heroStart from '../assets/chapters/chapter-01/fig-01-04-weighted-sum-result.png';
import heroEnd from '../assets/chapters/chapter-09/fig-09-01-garden-novel-views.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const repoUrl = 'https://github.com/kogum4/build-your-own-3dgs';

const features = [
  { icon: '🧮', title: t('features.scratch.title'), body: t('features.scratch.body') },
  { icon: '▶️', title: t('features.interactive.title'), body: t('features.interactive.body') },
  { icon: '📚', title: t('features.stepbystep.title'), body: t('features.stepbystep.body') },
];
---

<main id="main">
  <!-- ヒーロー -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="hero-inner">
      <h1 class="hero-title">
        Build Your Own<br />
        <span class="hero-accent">3D Gaussian Splatting</span>
      </h1>
      <p class="hero-tagline">{t('site.tagline')}</p>
      <p class="hero-lead">{t('hero.lead')}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={localizePath('/chapters/01/', lang)}>
          {t('chapter.start')} →
        </a>
        <a class="btn btn-outline" href={repoUrl} target="_blank" rel="noopener">GitHub</a>
      </div>

      <div class="hero-journey">
        <figure class="journey-item">
          <Image src={heroStart} alt="" width="280" densities={[1, 2]} />
          <figcaption>{lang === 'ja' ? '第1章: 最初の3つのガウシアン' : 'Chapter 1: your first three Gaussians'}</figcaption>
        </figure>
        <span class="journey-arrow" aria-hidden="true">→</span>
        <figure class="journey-item">
          <Image src={heroEnd} alt="" width="380" densities={[1, 2]} />
          <figcaption>{lang === 'ja' ? '第9章: 実写シーンの再構成' : 'Chapter 9: reconstructing a real scene'}</figcaption>
        </figure>
      </div>
    </div>
  </section>

  <!-- 特徴 -->
  <section class="features">
    <div class="features-inner">
      {
        features.map((f) => (
          <div class="feature-card">
            <span class="feature-icon" aria-hidden="true">
              {f.icon}
            </span>
            <h2>{f.title}</h2>
            <p>{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 章一覧 -->
  <section class="chapters" id="chapters">
    <div class="chapters-inner">
      <h2>{t('landing.chapters.title')}</h2>
      <p class="chapters-note">{t('landing.chapters.publishedNote')}</p>
      <ol class="chapter-grid">
        {
          chapterList.map((ch) =>
            ch.status === 'published' ? (
              <li>
                <a class="chapter-card" href={localizePath(`/chapters/${ch.slug}/`, lang)}>
                  <span class="card-num">{String(ch.number).padStart(2, '0')}</span>
                  <span class="card-body">
                    <span class="card-title">{ch.title[lang]}</span>
                    <span class="card-desc">{ch.description[lang]}</span>
                  </span>
                </a>
              </li>
            ) : (
              <li>
                <div class="chapter-card coming-soon" aria-disabled="true">
                  <span class="card-num">{String(ch.number).padStart(2, '0')}</span>
                  <span class="card-body">
                    <span class="card-title">
                      {ch.title[lang]}
                      <span class="soon-badge">{t('chapter.comingSoon')}</span>
                    </span>
                    <span class="card-desc">{ch.description[lang]}</span>
                  </span>
                </div>
              </li>
            ),
          )
        }
      </ol>
    </div>
  </section>
</main>

<style>
  /* --- ヒーロー --- */
  .hero {
    position: relative;
    overflow: hidden;
    padding: 72px 20px 56px;
    border-bottom: 1px solid var(--border-subtle);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(420px 300px at 12% 18%, var(--splat-red), transparent 70%),
      radial-gradient(480px 340px at 88% 10%, var(--splat-blue), transparent 70%),
      radial-gradient(520px 380px at 55% 95%, var(--splat-green), transparent 70%);
    opacity: 0.5;
    filter: blur(28px);
  }

  .hero-inner {
    max-width: 880px;
    margin: 0 auto;
    text-align: center;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(2rem, 5.5vw, 3.4rem);
    font-weight: 850;
    line-height: 1.15;
    letter-spacing: -0.01em;
  }

  .hero-accent {
    background: linear-gradient(100deg, #e05252, #1a9850 45%, var(--accent) 90%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .hero-tagline {
    margin: 18px 0 0;
    font-size: var(--text-lg);
    font-weight: 600;
  }

  .hero-lead {
    max-width: 640px;
    margin: 12px auto 0;
    color: var(--muted);
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 28px;
  }

  .hero-journey {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    margin-top: 48px;
    flex-wrap: wrap;
  }

  .journey-item {
    margin: 0;
  }

  .journey-item img {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-card-hover);
    background: #fff;
  }

  .journey-item figcaption {
    margin-top: 8px;
    color: var(--muted);
    font-size: var(--text-xs);
  }

  .journey-arrow {
    color: var(--faint);
    font-size: var(--text-2xl);
  }

  /* --- 特徴 --- */
  .features {
    padding: 56px 20px;
    background: var(--bg-subtle);
  }

  .features-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 1080px;
    margin: 0 auto;
  }

  .feature-card {
    padding: 24px;
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    background: var(--bg);
    box-shadow: var(--shadow-card);
  }

  .feature-icon {
    font-size: 1.6rem;
  }

  .feature-card h2 {
    margin: 10px 0 8px;
    font-size: var(--text-lg);
  }

  .feature-card p {
    margin: 0;
    color: var(--muted);
    font-size: var(--text-sm);
  }

  /* --- 章一覧 --- */
  .chapters {
    padding: 56px 20px 24px;
  }

  .chapters-inner {
    max-width: 1080px;
    margin: 0 auto;
  }

  .chapters h2 {
    margin: 0;
    font-size: var(--text-2xl);
  }

  .chapters-note {
    margin: 8px 0 24px;
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .chapter-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .chapter-card {
    display: flex;
    gap: 14px;
    height: 100%;
    padding: 16px 18px;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    color: var(--fg);
    background: var(--bg);
    box-shadow: var(--shadow-card);
    transition: box-shadow 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }

  a.chapter-card:hover {
    text-decoration: none;
    border-color: var(--accent);
    box-shadow: var(--shadow-card-hover);
    transform: translateY(-1px);
  }

  .card-num {
    flex: none;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-lg);
    font-weight: 700;
  }

  .coming-soon .card-num {
    color: var(--faint);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .card-title {
    font-weight: 700;
  }

  .card-desc {
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .coming-soon {
    background: var(--bg-subtle);
    color: var(--muted);
  }

  .soon-badge {
    display: inline-block;
    margin-left: 8px;
    padding: 1px 8px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--faint);
    vertical-align: 2px;
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .features-inner {
      grid-template-columns: 1fr;
    }

    .chapter-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
