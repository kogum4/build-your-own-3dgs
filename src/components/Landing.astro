---
import { Image } from 'astro:assets';
import { chapterList } from '../data/chapters';
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/utils';
import heroStart from '../assets/chapters/chapter-01/fig-01-04-weighted-sum-result.png';
import heroEnd from '../assets/chapters/chapter-09/fig-09-01-garden-novel-views.png';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const repoUrl = 'https://github.com/kogum4/build-your-own-3dgs';

const features = [
  { dot: 'var(--splat-r)', title: t('features.scratch.title'), body: t('features.scratch.body') },
  {
    dot: 'var(--splat-g)',
    title: t('features.interactive.title'),
    body: t('features.interactive.body'),
  },
  {
    dot: 'var(--splat-b)',
    title: t('features.stepbystep.title'),
    body: t('features.stepbystep.body'),
  },
];

const publishedCount = chapterList.filter((c) => c.status === 'published').length;
---

<main id="main">
  <!-- ヒーロー -->
  <section class="hero">
    <div class="hero-inner">
      <span class="tri-dots hero-dots" aria-hidden="true"><span></span><span></span><span></span></span>
      <h1 class="hero-title">Build Your Own<br />3D Gaussian<br />Splatting</h1>
      <p class="hero-tagline">{t('site.tagline')}</p>
      <p class="hero-lead">{t('hero.lead')}</p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={localizePath('/chapters/01/', lang)}>
          {t('chapter.start')} →
        </a>
        <a class="btn btn-outline" href={repoUrl} target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </section>

  <!-- 最初の1枚から最後の1枚へ -->
  <section class="journey">
    <div class="journey-inner">
      <figure class="journey-item">
        <figcaption>
          <b>CH.01</b>
          <span>{lang === 'ja' ? '最初の3つのガウシアン' : 'Your first three Gaussians'}</span>
        </figcaption>
        <Image src={heroStart} alt="" width="440" densities={[1, 2]} />
      </figure>
      <figure class="journey-item">
        <figcaption>
          <b>CH.09</b>
          <span>
            {
              lang === 'ja'
                ? '実写シーンの再構成 — 16章の到達点'
                : 'Reconstructing a real scene — where 16 chapters lead'
            }
          </span>
        </figcaption>
        <Image src={heroEnd} alt="" width="620" densities={[1, 2]} />
      </figure>
    </div>
  </section>

  <!-- 特徴 -->
  <section class="features">
    <div class="features-inner">
      {
        features.map((f) => (
          <div class="feature">
            <span class="feature-dot" style={`background:${f.dot}`} aria-hidden="true" />
            <h2>{f.title}</h2>
            <p>{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- 章一覧 -->
  <section class="chapters" id="chapters">
    <div class="chapters-inner">
      <div class="chapters-head">
        <h2>{t('landing.chapters.title')}</h2>
        <span class="chapters-note" aria-hidden="true">
          01–{String(publishedCount).padStart(2, '0')} PUBLISHED / {
            String(publishedCount + 1).padStart(2, '0')
          }–{String(chapterList.length).padStart(2, '0')} COMING
        </span>
      </div>
      <p class="visually-hidden">{t('landing.chapters.publishedNote')}</p>
      <ol class="chapter-grid">
        {
          chapterList.map((ch) =>
            ch.status === 'published' ? (
              <li>
                <a class="chapter-row" href={localizePath(`/chapters/${ch.slug}/`, lang)}>
                  <span class="row-num">{String(ch.number).padStart(2, '0')}</span>
                  <span class="row-main">
                    <span class="row-title">{ch.title[lang]}</span>
                    <span class="row-desc">{ch.description[lang]}</span>
                  </span>
                  <span class="row-st" aria-hidden="true">→</span>
                </a>
              </li>
            ) : (
              <li>
                <div class="chapter-row coming-soon" aria-disabled="true">
                  <span class="row-num">{String(ch.number).padStart(2, '0')}</span>
                  <span class="row-main">
                    <span class="row-title">{ch.title[lang]}</span>
                    <span class="row-desc">{ch.description[lang]}</span>
                  </span>
                  <span class="row-st">SOON</span>
                </div>
              </li>
            ),
          )
        }
      </ol>
    </div>
  </section>
</main>

<style>
  .hero-inner,
  .journey-inner,
  .features-inner,
  .chapters-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 28px;
  }

  /* --- ヒーロー --- */
  .hero {
    padding: 104px 0 96px;
  }

  .hero-dots {
    margin-bottom: 34px;
  }

  .hero-dots span {
    width: 9px;
    height: 9px;
  }

  .hero-title {
    margin: 0;
    font-size: clamp(2.4rem, 6vw, 4rem);
    font-weight: 800;
    line-height: 1.06;
    letter-spacing: -0.045em;
  }

  .hero-tagline {
    margin: 30px 0 0;
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.6;
  }

  .hero-lead {
    max-width: 37em;
    margin: 10px 0 0;
    color: var(--muted);
    font-size: var(--text-sm);
    line-height: 2;
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-top: 44px;
  }

  /* --- journey --- */
  .journey {
    border-top: 1px solid var(--border-ink);
    padding: 60px 0;
  }

  .journey-inner {
    display: grid;
    grid-template-columns: 1fr 1.4fr;
    gap: 48px;
    align-items: start;
  }

  .journey-item {
    margin: 0;
  }

  .journey-item img {
    display: block;
    width: 100%;
    height: auto;
  }

  .journey-item figcaption {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .journey-item figcaption b {
    color: var(--fg);
    font-weight: 600;
  }

  /* --- 特徴 --- */
  .features {
    border-top: 1px solid var(--border-ink);
  }

  .features-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
  }

  .feature {
    padding: 44px 36px 52px 0;
  }

  .feature + .feature {
    padding-left: 36px;
    border-left: 1px solid var(--border-subtle);
  }

  .feature-dot {
    display: block;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    margin-bottom: 20px;
  }

  .feature h2 {
    margin: 0 0 8px;
    font-size: var(--text-base);
    font-weight: 700;
  }

  .feature p {
    margin: 0;
    color: var(--muted);
    font-size: 0.8125rem;
    line-height: 1.9;
  }

  /* --- 章一覧 --- */
  .chapters {
    border-top: 1px solid var(--border-ink);
    padding: 64px 0 40px;
  }

  .chapters-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 40px;
  }

  .chapters-head h2 {
    margin: 0;
    font-size: var(--text-2xl);
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .chapters-note {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
    white-space: nowrap;
  }

  .chapter-grid {
    columns: 2;
    column-gap: 64px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .chapter-grid li {
    break-inside: avoid;
  }

  .chapter-row {
    display: flex;
    gap: 16px;
    align-items: baseline;
    padding: 12px 0;
    border-bottom: 1px solid var(--border-subtle);
    color: var(--fg);
  }

  a.chapter-row:hover {
    text-decoration: none;
    border-bottom-color: var(--border-ink);
  }

  a.chapter-row:hover .row-num {
    color: var(--fg);
  }

  .row-num {
    flex: none;
    width: 22px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--faint);
  }

  .row-main {
    flex: 1;
    min-width: 0;
  }

  .row-title {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.7;
  }

  .row-desc {
    display: none;
  }

  .row-st {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--faint);
    white-space: nowrap;
  }

  .coming-soon {
    opacity: 0.45;
  }

  @media (max-width: 860px) {
    .hero {
      padding: 72px 0 64px;
    }

    .journey-inner {
      grid-template-columns: 1fr;
    }

    .features-inner {
      grid-template-columns: 1fr;
    }

    .feature {
      padding: 28px 0;
    }

    .feature + .feature {
      padding-left: 0;
      border-left: 0;
      border-top: 1px solid var(--border-subtle);
    }

    .chapter-grid {
      columns: 1;
    }
  }
</style>
