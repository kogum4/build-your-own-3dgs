---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const repoUrl = 'https://github.com/kogum4/build-your-own-3dgs';
const ccUrl =
  lang === 'ja'
    ? 'https://creativecommons.org/licenses/by/4.0/deed.ja'
    : 'https://creativecommons.org/licenses/by/4.0/';
const mitUrl = `${repoUrl}/blob/main/LICENSE`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p>
      <strong>Build Your Own 3D Gaussian Splatting</strong> — {t('site.tagline')}
    </p>
    <p class="footer-meta">
      © {year} kogum4
      <span class="sep" aria-hidden="true">·</span>
      {t('footer.textLicense')}: <a href={ccUrl} target="_blank" rel="noopener license">CC BY 4.0</a>
      <span class="sep" aria-hidden="true">·</span>
      {t('footer.codeLicense')}: <a href={mitUrl} target="_blank" rel="noopener license">MIT</a>
      <span class="sep" aria-hidden="true">·</span>
      {t('footer.sourceOn')} <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 64px;
    padding: 32px 20px 40px;
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-subtle);
    color: var(--muted);
    font-size: var(--text-sm);
  }

  .footer-inner {
    max-width: 1360px;
    margin: 0 auto;
  }

  .footer-inner p {
    margin: 4px 0;
  }

  .sep {
    margin: 0 6px;
    color: var(--faint);
  }
</style>
