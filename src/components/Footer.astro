---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const repoUrl = 'https://github.com/kogum4/build-your-own-3dgs';
const ccUrl =
  lang === 'ja'
    ? 'https://creativecommons.org/licenses/by/4.0/deed.ja'
    : 'https://creativecommons.org/licenses/by/4.0/';
const mitUrl = `${repoUrl}/blob/main/LICENSE`;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="footer-inner">
    <p>
      <strong>Build Your Own 3D Gaussian Splatting</strong> — {t('site.tagline')}
    </p>
    <p class="footer-meta">
      © {year} kogum4
      <span class="sep" aria-hidden="true">·</span>
      {t('footer.textLicense')}: <a href={ccUrl} target="_blank" rel="noopener license">CC BY 4.0</a>
      <span class="sep" aria-hidden="true">·</span>
      {t('footer.codeLicense')}: <a href={mitUrl} target="_blank" rel="noopener license">MIT</a>
      <span class="sep" aria-hidden="true">·</span>
      {t('footer.sourceOn')} <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 80px;
    padding: 28px 28px 36px;
    border-top: 1px solid var(--border-ink);
    color: var(--muted);
    font-size: var(--text-xs);
    line-height: 1.9;
  }

  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
  }

  .footer-inner p {
    margin: 4px 0;
  }

  .footer-inner strong {
    color: var(--fg);
    letter-spacing: -0.01em;
  }

  .footer-meta {
    font-family: var(--font-mono);
    color: var(--faint);
  }

  .footer-meta a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-meta a:hover {
    color: var(--fg);
  }

  .sep {
    margin: 0 6px;
    color: var(--faint);
  }
</style>
