---
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/utils';
import LangSwitch from './LangSwitch.astro';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const repoUrl = 'https://github.com/kogum4/build-your-own-3dgs';
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand" href={localizePath('/', lang)}>Build Your Own 3DGS</a>
    <nav class="header-nav" aria-label="Site">
      <a href={`${localizePath('/', lang)}#chapters`}>{t('nav.chapters')}</a>
      <a href={repoUrl} target="_blank" rel="noopener">GitHub</a>
      <LangSwitch lang={lang} />
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: var(--header-height);
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    max-width: 1280px;
    height: 100%;
    margin: 0 auto;
    padding: 0 28px;
  }

  .brand {
    color: var(--fg);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }

  .brand:hover {
    text-decoration: none;
    opacity: 0.7;
  }

  .header-nav {
    display: flex;
    align-items: center;
    gap: 24px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--muted);
  }

  .header-nav a {
    color: var(--muted);
    white-space: nowrap;
  }

  .header-nav a:hover {
    color: var(--fg);
    text-decoration: none;
  }

  @media (max-width: 640px) {
    .header-inner {
      padding: 0 20px;
    }

    .header-nav {
      gap: 14px;
    }
  }
</style>
