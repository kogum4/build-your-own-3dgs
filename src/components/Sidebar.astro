---
import { chapterList } from '../data/chapters';
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentSlug?: string;
}

const { lang, currentSlug } = Astro.props;
const t = useTranslations(lang);
---

<nav class="sidebar" aria-label={t('nav.chapters')}>
  <details class="sidebar-details">
    <summary class="sidebar-summary">{t('nav.chapters')}</summary>
    <p class="rail-label" aria-hidden="true">Chapters</p>
    <ol class="chapter-list">
      {
        chapterList.map((ch) =>
          ch.status === 'published' ? (
            <li>
              <a
                class:list={['chapter-link', { current: ch.slug === currentSlug }]}
                href={localizePath(`/chapters/${ch.slug}/`, lang)}
                aria-current={ch.slug === currentSlug ? 'page' : undefined}
              >
                <span class="ch-num">{ch.slug}</span>
                <span class="ch-title">{ch.title[lang]}</span>
              </a>
            </li>
          ) : (
            <li>
              <span class="chapter-link coming-soon" title={t('chapter.comingSoon')}>
                <span class="ch-num">{ch.slug}</span>
                <span class="ch-title">{ch.title[lang]}</span>
              </span>
            </li>
          ),
        )
      }
    </ol>
  </details>
</nav>

<style>
  .sidebar {
    font-size: 0.8125rem;
  }

  .sidebar-summary {
    display: none;
  }

  .rail-label {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .chapter-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .chapter-link {
    display: flex;
    align-items: baseline;
    gap: 12px;
    padding: 5px 0;
    color: var(--muted);
    line-height: 1.55;
  }

  .chapter-link:hover {
    color: var(--fg);
    text-decoration: none;
  }

  .chapter-link.current {
    color: var(--fg);
    font-weight: 700;
  }

  .ch-num {
    flex: none;
    color: var(--faint);
    font-family: var(--font-mono);
    font-variant-numeric: tabular-nums;
    font-size: 0.6875rem;
  }

  .chapter-link.current .ch-num {
    color: var(--fg);
  }

  .coming-soon {
    opacity: 0.4;
    cursor: default;
  }

  .coming-soon:hover {
    color: var(--muted);
  }

  /* デスクトップでは details を常時開いた見た目に */
  @media (min-width: 961px) {
    .sidebar-details {
      display: contents;
    }
  }

  /* モバイルでは折りたたみメニュー */
  @media (max-width: 960px) {
    .sidebar {
      margin-bottom: 20px;
    }

    .sidebar-details {
      border: 1px solid var(--border-ink);
      background: var(--bg);
    }

    .sidebar-details[open] {
      padding-bottom: 8px;
    }

    .sidebar-details .rail-label {
      display: none;
    }

    .sidebar-summary {
      display: block;
      padding: 10px 14px;
      cursor: pointer;
      font-weight: 600;
    }

    .chapter-list {
      padding: 0 14px;
    }
  }
</style>

<script>
  // デスクトップでは details を強制的に開く (CSS の display:contents と併用)
  const mq = window.matchMedia('(min-width: 961px)');
  const details = document.querySelectorAll<HTMLDetailsElement>('.sidebar-details');
  const sync = () => {
    if (mq.matches) details.forEach((d) => (d.open = true));
  };
  sync();
  mq.addEventListener('change', sync);
</script>
