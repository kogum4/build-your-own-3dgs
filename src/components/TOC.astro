---
import type { MarkdownHeading } from 'astro';
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props {
  lang: Lang;
  headings: MarkdownHeading[];
}

const { lang, headings } = Astro.props;
const t = useTranslations(lang);
const items = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  items.length > 0 && (
    <nav class="toc" aria-label={t('chapter.toc')}>
      <p class="toc-title">{t('chapter.toc')}</p>
      <ul>
        {items.map((h) => (
          <li class={`depth-${h.depth}`}>
            <a href={`#${h.slug}`}>{h.text}</a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<style>
  .toc {
    font-size: var(--text-xs);
    line-height: 1.6;
  }

  .toc-title {
    margin: 0 0 14px;
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 400;
    color: var(--faint);
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .toc ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .toc li a {
    display: block;
    padding: 4px 0;
    color: var(--faint);
  }

  .toc li.depth-3 a {
    padding-left: 14px;
  }

  .toc li a:hover {
    color: var(--fg);
    text-decoration: none;
  }

  .toc li a.active {
    color: var(--fg);
    font-weight: 600;
  }
</style>

<script>
  // スクロール位置に応じて現在のセクションをハイライト
  const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.toc a[href^="#"]');
  if (tocLinks.length > 0) {
    const map = new Map<Element, HTMLAnchorElement>();
    for (const link of tocLinks) {
      const id = decodeURIComponent(link.hash.slice(1));
      const target = document.getElementById(id);
      if (target) map.set(target, link);
    }
    let activeLink: HTMLAnchorElement | null = null;
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            activeLink?.classList.remove('active');
            activeLink = map.get(entry.target) ?? null;
            activeLink?.classList.add('active');
          }
        }
      },
      { rootMargin: '-64px 0px -75% 0px' },
    );
    for (const el of map.keys()) observer.observe(el);
  }
</script>
