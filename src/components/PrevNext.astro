---
import { getPrevNext } from '../data/chapters';
import type { Lang } from '../i18n/ui';
import { useTranslations, localizePath } from '../i18n/utils';

interface Props {
  lang: Lang;
  currentSlug: string;
}

const { lang, currentSlug } = Astro.props;
const t = useTranslations(lang);
const { prev, next } = getPrevNext(currentSlug);
---

<nav class="prev-next" aria-label="Chapter navigation">
  {
    prev ? (
      <a class="pn-card prev" href={localizePath(`/chapters/${prev.slug}/`, lang)} rel="prev">
        <span class="pn-label">← {t('chapter.prev')}</span>
        <span class="pn-title">
          {t('chapter.label', { n: prev.number })}: {prev.title[lang]}
        </span>
      </a>
    ) : (
      <span class="pn-spacer" />
    )
  }
  {
    next ? (
      <a class="pn-card next" href={localizePath(`/chapters/${next.slug}/`, lang)} rel="next">
        <span class="pn-label">{t('chapter.next')} →</span>
        <span class="pn-title">
          {t('chapter.label', { n: next.number })}: {next.title[lang]}
        </span>
      </a>
    ) : (
      <span class="pn-spacer" />
    )
  }
</nav>

<style>
  .prev-next {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 72px;
    padding-top: 28px;
    border-top: 1px solid var(--border-ink);
  }

  .pn-card {
    display: flex;
    flex-direction: column;
    gap: 2px;
    color: var(--fg);
  }

  .pn-card:hover {
    text-decoration: none;
    opacity: 0.6;
  }

  .pn-card.next {
    text-align: right;
  }

  .pn-label {
    color: var(--faint);
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    letter-spacing: 0.06em;
  }

  .pn-title {
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  @media (max-width: 640px) {
    .prev-next {
      grid-template-columns: 1fr;
    }

    .pn-card.next {
      text-align: left;
    }
  }
</style>
