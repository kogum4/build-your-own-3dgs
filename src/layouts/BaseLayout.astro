---
import type { Lang } from '../i18n/ui';
import { withBase } from '../i18n/utils';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/tokens.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonicalPath?: string;
  alternates?: { lang: Lang; path: string }[];
  ogType?: 'website' | 'article';
}

const { title, description, lang, canonicalPath, alternates, ogType } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <link rel="sitemap" href={withBase('/sitemap-index.xml')} />
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <SEO {title} {description} {lang} {canonicalPath} {alternates} {ogType} />
  </head>
  <body>
    <a class="skip-link" href="#main">{lang === 'ja' ? '本文へスキップ' : 'Skip to content'}</a>
    <Header {lang} />
    <slot />
    <Footer {lang} />
  </body>
</html>
